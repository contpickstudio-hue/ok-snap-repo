{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "site": false
    }
  },
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api?path=sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/api?path=robots.txt"
    },
    {
      "source": "/recipe/:slug",
      "destination": "/api?path=blog-html/:slug"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api?path=$1"
    },
    {
      "source": "/api",
      "destination": "/api?path="
    }
  ],
  "crons": [
    {
      "path": "/api/sync-recipes",
      "schedule": "0 2 * * *"
    }
  ]
}
