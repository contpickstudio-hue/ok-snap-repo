{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "site": false
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api?path=$1"
    },
    {
      "source": "/api",
      "destination": "/api?path="
    }
  ],
  "crons": [
    {
      "path": "/api/sync-recipes",
      "schedule": "0 2 * * *"
    }
  ]
}
